# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Security - NEVER COMMIT
.audit_secret
*.key
*.pem

# Audit Pipeline Data
# These files contain sensitive/proprietary data and are large (>100MB)
# See assets/audit/README.md for setup instructions
# Patterns:
#   - *.json: DAM asset catalog and generated fingerprints
#   - *.txt: URL lists and crawl data
#   - *.log: Runtime logs and debug output
#   - *.bak: Backup files
assets/audit/*.json
assets/audit/*.txt
assets/audit/*.log
assets/audit/*.bak
!assets/audit/README.md
!assets/audit/.gitkeep
