# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Security - NEVER COMMIT
.audit_secret
*.key
*.pem

# Audit Pipeline Data
# These files contain sensitive/proprietary data and are large (>100MB)
# See assets/audit/README.md for setup instructions
assets/audit/*.json          # DAM asset catalog and generated fingerprints
assets/audit/*.txt           # URL lists and crawl data (except .gitkeep)
assets/audit/*.log           # Runtime logs and debug output
!assets/audit/README.md      # Keep documentation
!assets/audit/.gitkeep       # Track directory structure
